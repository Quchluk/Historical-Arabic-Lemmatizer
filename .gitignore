# Gitignore for Python Project

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.mypy_cache/

# --- Virtual Environments ---
venv/
env/
ENV/
.venv/

# --- IDEs ---
.idea/
.vscode/
*.swp
*.swo
*.iml
*.iws
.idea_modules/

# --- Operating System ---
.DS_Store
.DS_Store?
._*
.Trashes
.AppleDouble
.LSOverride
Thumbs.db
desktop.ini

# --- Environment Variables (CRITICAL) ---
.env
.env.local
.env.*.local
! .env.example

# --- Logs ---
*.log
logs/
metadata_extraction.log

# --- Data & Artifacts ---
data/
models/
checkpoints/
embeddings/
.cache/
huggingface/
# Keep essential data structure if needed, but ignore content
!data/.keep
!models/.keep

# --- Notebooks ---
.ipynb_checkpoints/
*.ipynb

# --- Legacy/Root level folders to ignore ---
/db
/db_training
/jobs
/lemma_registry
/camel_lemmatized
/clean_lemmatized
/spread_validation
/validation_reports
/farasa_lemmatized
/llm_lemmatized
/TF-LLM-lemmatizer
/Quranic
/tools
/farasapy
/farasa jar

# --- Specific File Types & Large Files ---
*.pt
*.pth
*.pkl
*.pickle
*.parquet
*.csv.gz
openiti_metadata.parquet

# --- State Files ---
pipeline_state.json
pipeline_parallel_state.json
tf_lemma_cache.json

# --- Archive ---
_archive/
# scripts/  <-- Kept if they are useful dev tools, otherwise ignore

